{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_DB_HOST;Port=5432;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;"
  },
  "JwtSettings": {
    "SecurityKey": "REPLACE_WITH_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS",
    "ValidIssuer": "BoardVerseAPI",
    "ValidAudience": "BoardVerseApp",
    "ExpiryInMinutes": 1440
  },
  "Authentication": {
    "Google": {
      "ClientId": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
      "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
    }
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "your_email@gmail.com",
    "Password": "YOUR_APP_SPECIFIC_PASSWORD",
    "From": "your_email@gmail.com",
    "EnableSsl": true
  },
  "Redis": {
    "Configuration": "YOUR_REDIS_HOST:6379",
    "InstanceName": "BoardVerseRedis"
  }
}